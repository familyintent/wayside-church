---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../lib/content";
import { absoluteUrl, withBase } from "../lib/paths";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const { title, description = site.meta.description, image = site.meta.socialImage } = Astro.props;
const pageTitle = title ? `${title} | ${site.church.name}` : `${site.church.name} - The Church in ${site.church.city}, ${site.church.state}`;
const canonicalUrl = absoluteUrl(Astro.url.pathname, site.meta.siteUrl);
const socialImageUrl = absoluteUrl(image, site.meta.siteUrl);
const logoUrl = absoluteUrl(site.meta.logo, site.meta.siteUrl);
const siteUrl = absoluteUrl("/", site.meta.siteUrl);
const churchId = `${siteUrl}#church`;
const webSiteId = `${siteUrl}#website`;
const sameAs = [site.links.facebook, site.links.instagram, site.links.youtube].filter(Boolean);
const churchSchema = {
  "@context": "https://schema.org",
  "@type": "Church",
  "@id": churchId,
  name: site.church.name,
  url: siteUrl,
  logo: logoUrl,
  image: socialImageUrl,
  description: site.meta.description,
  telephone: site.contact.phone,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.contact.addressLine1,
    addressLocality: site.contact.addressLocality,
    addressRegion: site.contact.addressRegion,
    postalCode: site.contact.postalCode,
    addressCountry: site.contact.addressCountry,
  },
  sameAs,
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Sunday",
      opens: "10:00",
      closes: "11:30",
      description: site.service.primary.label,
    },
  ],
};
const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": webSiteId,
  name: site.church.name,
  url: siteUrl,
  publisher: { "@id": churchId },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#fbfaf6" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={withBase("/favicon.png")} type="image/png" />
    <link rel="icon" href={withBase("/favicon-32.png")} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <link rel="manifest" href={withBase("/site.webmanifest")} />
    <meta property="og:site_name" content={site.church.name} />
    <meta property="og:locale" content={site.meta.locale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Wayside Church in Charlton, MA" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(churchSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
