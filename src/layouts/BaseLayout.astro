---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../lib/content";
import { imageSize } from "../lib/images";
import { absoluteUrl, withBase, withoutBase } from "../lib/paths";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  robots?: string;
  extraSchemas?: unknown[];
};

const {
  title,
  description = site.meta.description,
  image = site.meta.socialImage,
  imageAlt,
  imageWidth,
  imageHeight,
  robots = "index, follow",
  extraSchemas = [],
} = Astro.props;
const pageTitle = title
  ? title.includes(site.church.name)
    ? title
    : `${title} | ${site.church.name}`
  : `${site.church.name} | Church in ${site.church.city}, ${site.church.state}`;
const canonicalUrl = absoluteUrl(Astro.url.pathname, site.meta.siteUrl);
const socialImageUrl = absoluteUrl(image, site.meta.siteUrl);
const socialImageAlt = imageAlt || site.meta.socialImageAlt || `${site.church.name} in ${site.church.city}, ${site.church.state}`;
const socialImageSize =
  imageWidth && imageHeight
    ? { width: imageWidth, height: imageHeight }
    : imageSize(image) || imageSize(site.meta.socialImage) || { width: 1200, height: 630 };
const localEntityImageSources = site.images.localEntity || [];
const churchImageSources = [site.meta.socialImage, ...localEntityImageSources, site.images.community];
const churchImageUrls = Array.from(new Set(churchImageSources.map((imagePath) => absoluteUrl(imagePath, site.meta.siteUrl))));
const churchPhotoObjects = churchImageSources.map((imagePath) => {
  const dimensions = imageSize(imagePath);
  return {
    "@type": "ImageObject",
    url: absoluteUrl(imagePath, site.meta.siteUrl),
    caption:
      imagePath === site.meta.socialImage
        ? site.meta.socialImageAlt
        : localEntityImageSources.includes(imagePath)
          ? "Real Wayside Church photo prepared for local church search results"
        : "Wayside Church family sharing fellowship in Charlton, Massachusetts",
    ...(dimensions ? { width: dimensions.width, height: dimensions.height } : {}),
  };
});
const logoUrl = absoluteUrl(site.meta.logo, site.meta.siteUrl);
const siteUrl = absoluteUrl("/", site.meta.siteUrl);
const teachingFeedUrl = absoluteUrl("/teaching-feed.xml", site.meta.siteUrl);
const churchId = `${siteUrl}#church`;
const webSiteId = `${siteUrl}#website`;
const normalizedPath = withoutBase(Astro.url.pathname);
const sameAs = [site.links.facebook, site.links.instagram, site.links.youtube, site.links.maps].filter(Boolean);
const phoneNumber = site.contact.phoneHref.replace(/^tel:/, "");
const churchDescription = site.church.description || site.meta.description;
const alternateNames = site.church.alternateNames || [];
const searchTopics = site.church.searchTopics || [
  site.church.name,
  `Church in ${site.church.city}, ${site.church.state}`,
  `Sunday worship in ${site.church.city}, ${site.church.state}`,
];
const nearbyAreaServed = (site.church.nearbyCommunities || []).map((name) => ({
  "@type": "City",
  name,
}));
const amenityFeatures = (site.visitDetails?.amenityFeatures || []).map((name) => ({
  "@type": "LocationFeatureSpecification",
  name,
  value: true,
}));
const visitorSearchDetails = (site.visitDetails?.searchDetails || []).map((detail) => ({
  "@type": "PropertyValue",
  name: detail.name,
  value: detail.value,
}));
const churchSchema = {
  "@context": "https://schema.org",
  "@type": "Church",
  "@id": churchId,
  name: site.church.name,
  alternateName: alternateNames,
  url: siteUrl,
  slogan: site.church.tagline,
  logo: logoUrl,
  image: churchImageUrls,
  photo: churchPhotoObjects,
  description: churchDescription,
  disambiguatingDescription: `${site.church.name} is a local church at ${site.contact.addressLine1} in ${site.contact.cityStateZip}.`,
  keywords: searchTopics,
  knowsAbout: searchTopics,
  mainEntityOfPage: siteUrl,
  telephone: phoneNumber,
  hasMap: site.links.maps,
  isAccessibleForFree: true,
  publicAccess: true,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.contact.addressLine1,
    addressLocality: site.contact.addressLocality,
    addressRegion: site.contact.addressRegion,
    postalCode: site.contact.postalCode,
    addressCountry: site.contact.addressCountry,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.contact.latitude,
    longitude: site.contact.longitude,
  },
  amenityFeature: amenityFeatures,
  contactPoint: {
    "@type": "ContactPoint",
    telephone: phoneNumber,
    contactType: "church office",
    areaServed: `${site.church.city}, ${site.church.state}`,
    availableLanguage: "English",
  },
  areaServed: [
    {
      "@type": "City",
      name: `${site.church.city}, ${site.church.state}`,
    },
    ...nearbyAreaServed,
    {
      "@type": "AdministrativeArea",
      name: "Worcester County, MA",
    },
  ],
  sameAs,
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Sunday",
      opens: "09:00",
      closes: "11:30",
      description: `${site.service.coffee.label} and ${site.service.primary.label}`,
    },
  ],
  openingHours: "Su 09:00-11:30",
  additionalProperty: [
    {
      "@type": "PropertyValue",
      name: site.service.primary.label,
      value: `${site.service.primary.day} at ${site.service.primary.time}`,
    },
    {
      "@type": "PropertyValue",
      name: site.service.coffee.label,
      value: `${site.service.coffee.day} at ${site.service.coffee.time}`,
    },
    site.church.faithTradition && {
      "@type": "PropertyValue",
      name: "Faith tradition",
      value: site.church.faithTradition,
    },
    {
      "@type": "PropertyValue",
      name: "Mission",
      value: site.church.mission,
    },
    ...visitorSearchDetails,
  ].filter(Boolean),
};
const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": webSiteId,
  name: site.church.name,
  alternateName: alternateNames,
  url: siteUrl,
  description: site.meta.description,
  publisher: { "@id": churchId },
  about: { "@id": churchId },
  mainEntity: { "@id": churchId },
  keywords: searchTopics,
  inLanguage: "en-US",
};
const siteNavigationSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${siteUrl}#site-navigation`,
  name: `${site.church.name} primary navigation`,
  itemListElement: site.navigation.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "SiteNavigationElement",
      name: item.label,
      url: absoluteUrl(item.href, site.meta.siteUrl),
    },
  })),
};
const pageSchemaType =
  normalizedPath === "/about/" || normalizedPath === "/beliefs/" || normalizedPath === "/leadership/"
    ? "AboutPage"
    : normalizedPath === "/contact/" || normalizedPath === "/directions/"
      ? "ContactPage"
      : normalizedPath === "/ministries/" ||
          normalizedPath === "/events/" ||
          normalizedPath === "/teaching/" ||
          normalizedPath === "/sermons/"
        ? "CollectionPage"
        : "WebPage";
const webPageSchema =
  robots.includes("noindex")
    ? null
    : {
        "@context": "https://schema.org",
        "@type": pageSchemaType,
        "@id": `${canonicalUrl}#webpage`,
        url: canonicalUrl,
        name: pageTitle,
        description,
        keywords: searchTopics,
        isPartOf: { "@id": webSiteId },
        about: { "@id": churchId },
        mainEntity: { "@id": churchId },
        publisher: { "@id": churchId },
        primaryImageOfPage: {
          "@type": "ImageObject",
          url: socialImageUrl,
          caption: socialImageAlt,
          width: socialImageSize.width,
          height: socialImageSize.height,
        },
        inLanguage: "en-US",
      };
const currentNavItem = site.navigation.find((item) => item.href === normalizedPath || item.href === `${normalizedPath}/`);
const normalizedPathKey = normalizedPath.endsWith("/") ? normalizedPath : `${normalizedPath}/`;
const pageLabels: Record<string, string> = {
  "/about/": "About",
  "/beliefs/": "Beliefs",
  "/church-in-charlton-ma/": "Church in Charlton",
  "/contact/": "Contact",
  "/directions/": "Directions",
  "/events/": "Events",
  "/families/": "Families",
  "/giving/": "Giving",
  "/leadership/": "Leadership",
  "/ministries/": "Ministries",
  "/nearby-communities/": "Nearby Communities",
  "/new-to-church/": "New to Church",
  "/newsletter/": "Newsletter",
  "/plan-a-visit/": "Plan a Visit",
  "/sermons/": "Sermons",
  "/sitemap/": "Site Map",
  "/start-here/": "Start Here",
  "/sunday-worship/": "Sunday Worship",
  "/teaching/": "Teaching",
  "/visitor-faq/": "Visitor FAQ",
};
const fallbackBreadcrumbLabel = (title || pageTitle).replace(` | ${site.church.name}`, "");
const breadcrumbLabel = currentNavItem?.label || pageLabels[normalizedPathKey] || fallbackBreadcrumbLabel;
const breadcrumbItems =
  normalizedPath === "/" || robots.includes("noindex")
    ? []
    : [
        {
          name: "Home",
          href: "/",
          item: siteUrl,
        },
        {
          name: breadcrumbLabel,
          href: normalizedPathKey,
          item: canonicalUrl,
        },
      ];
const breadcrumbSchema =
  breadcrumbItems.length === 0
    ? null
    : {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbItems.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: item.item,
        })),
      };
const contentSecurityPolicy = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "frame-src https://www.youtube-nocookie.com https://www.youtube.com",
  "form-action 'self'",
  "img-src 'self' data: https://*.ytimg.com",
  "font-src 'self'",
  "style-src 'self' 'unsafe-inline'",
  "script-src 'self' 'unsafe-inline'",
  "connect-src 'self'",
  "manifest-src 'self'",
  "worker-src 'none'",
  "upgrade-insecure-requests",
].join("; ");
const schemas = [churchSchema, webSiteSchema, siteNavigationSchema, webPageSchema, breadcrumbSchema, ...extraSchemas].filter(Boolean);
const toJsonLd = (schema: unknown) => JSON.stringify(schema).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#fbfaf6" />
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/atom+xml" title={`${site.church.name} Teaching Feed`} href={teachingFeedUrl} />
    <link rel="icon" href={withBase("/favicon.png")} type="image/png" />
    <link rel="icon" href={withBase("/favicon-32.png")} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <link rel="manifest" href={withBase("/site.webmanifest")} />
    <meta property="og:site_name" content={site.church.name} />
    <meta property="og:locale" content={site.meta.locale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:width" content={String(socialImageSize.width)} />
    <meta property="og:image:height" content={String(socialImageSize.height)} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <title>{pageTitle}</title>
    {schemas.map((schema) => <script type="application/ld+json" set:html={toJsonLd(schema)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      {
        breadcrumbItems.length > 0 && (
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <div class="shell">
              <ol class="breadcrumb__list">
                {breadcrumbItems.map((item, index) => (
                  <li>
                    {index === breadcrumbItems.length - 1 ? (
                      <span aria-current="page">{item.name}</span>
                    ) : (
                      <a href={withBase(item.href)}>{item.name}</a>
                    )}
                  </li>
                ))}
              </ol>
            </div>
          </nav>
        )
      }
      <slot />
    </main>
    <Footer />
  </body>
</html>
