---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../lib/content";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const { title, description = site.meta.description } = Astro.props;
const pageTitle = title ? `${title} | ${site.church.name}` : `${site.church.name} - The Church in ${site.church.city}, ${site.church.state}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fbfaf6" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{pageTitle}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("wayside-theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = savedTheme || (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
