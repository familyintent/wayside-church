---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/content";
import { absoluteUrl, withBase } from "../lib/paths";
import { getTeachingPagePath } from "../lib/teaching-routes";
import { getRecentTeachings } from "../lib/youtube";

const recentTeachings = await getRecentTeachings(site.youtube, 6);
const recentTeachingLinks = recentTeachings.map((video) => ({
  label: video.title,
  href: getTeachingPagePath(video),
}));

const groups = [
  {
    title: "Start Here",
    description: "Pages for guests, seekers, and people getting oriented.",
    links: [
      { label: "Home", href: "/" },
      { label: "Start Here", href: "/start-here/" },
      { label: "New to Church", href: "/new-to-church/" },
      { label: "Plan a Visit", href: "/plan-a-visit/" },
      { label: "Visitor FAQ", href: "/visitor-faq/" },
    ],
  },
  {
    title: "Visit Wayside",
    description: "Practical details for Sunday morning in Charlton.",
    links: [
      { label: "Sunday Worship", href: "/sunday-worship/" },
      { label: "Directions", href: "/directions/" },
      { label: "Events", href: "/events/" },
      { label: "Contact", href: "/contact/" },
    ],
  },
  {
    title: "Local Church Pages",
    description: "Helpful pages for neighbors searching for a church in Charlton and nearby towns.",
    links: [
      { label: "Church in Charlton, MA", href: "/church-in-charlton-ma/" },
      { label: "Nearby Communities", href: "/nearby-communities/" },
      { label: "Families", href: "/families/" },
    ],
  },
  {
    title: "Teaching and Beliefs",
    description: "Learn what shapes our church and listen to recent teaching.",
    links: [
      { label: "Teaching", href: "/teaching/" },
      { label: "Sermons", href: "/sermons/" },
      { label: "Beliefs", href: "/beliefs/" },
      { label: "About", href: "/about/" },
      { label: "Leadership", href: "/leadership/" },
    ],
  },
  {
    title: "Church Life",
    description: "Ways to connect, serve, and stay in touch.",
    links: [
      { label: "Ministries", href: "/ministries/" },
      { label: "Newsletter", href: "/newsletter/" },
      { label: "Giving", href: "/giving/" },
      { label: "Site Map", href: "/sitemap/" },
    ],
  },
  ...(recentTeachingLinks.length > 0
    ? [
        {
          title: "Recent Teaching Pages",
          description: "Automatically generated pages for recent Wayside teaching videos.",
          links: recentTeachingLinks,
        },
      ]
    : []),
];
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Wayside Church site map",
  itemListElement: groups.flatMap((group) => group.links).map((link, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: link.label,
    url: absoluteUrl(link.href, site.meta.siteUrl),
  })),
};
---

<BaseLayout title="Site Map for Wayside Church" description="Find every main page on the Wayside Church website, including visitor information, Sunday worship, teaching, ministries, beliefs, and local church pages." extraSchemas={[itemListSchema]}>
  <section class="page-hero page-hero--center">
    <div class="shell page-hero__inner">
      <p class="eyebrow">Site map</p>
      <h1>Find your way around Wayside Church.</h1>
      <p>Every page here is part of the public Wayside Church website. Start with the visitor pages, explore teaching and beliefs, or find practical Sunday details.</p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="Website pages" title="A clear path to every main page">
        <p>This page keeps the deeper visitor and local search pages easy to find without crowding the main navigation.</p>
      </SectionIntro>

      <div class="site-map-grid">
        {groups.map((group) => {
          const id = `site-map-${group.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
          return (
            <section class="site-map-group" aria-labelledby={id}>
              <h2 id={id}>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.links.map((link) => (
                  <li><a href={withBase(link.href)}>{link.label}</a></li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
