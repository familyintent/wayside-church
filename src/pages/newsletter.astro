---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { site } from "../lib/content";
---

<BaseLayout title="Wayside Church Newsletter" description="Sign up for Wayside Church updates, announcements, ministry rhythms, and next steps.">
  <section class="page-hero page-hero--center">
    <div class="shell page-hero__inner">
      <p class="eyebrow">Newsletter</p>
      <h1>{site.newsletterPage.title}</h1>
      <p>{site.newsletterPage.intro}</p>
      <div class="page-hero__actions">
        <ButtonLink href={site.links.newsletter}>Sign Up</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
