---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import ChurchContactBlock from "../components/ChurchContactBlock.astro";
import LatestTeaching from "../components/LatestTeaching.astro";
import MinistryList from "../components/MinistryList.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/content";
import { imageSize, imageSizesFor, imageSrcset } from "../lib/images";
import { withBase } from "../lib/paths";
import { getTeachingVideoSchemas } from "../lib/schema";
import { getLatestTeaching } from "../lib/youtube";

const latestTeaching = await getLatestTeaching(site.youtube);
const homeSchemas = latestTeaching ? getTeachingVideoSchemas([latestTeaching], "/") : [];
const heroImageSize = imageSize(site.images.hero);
const communityImageSize = imageSize(site.images.community);
const heroImageSrcset = imageSrcset(site.images.hero);
const communityImageSrcset = imageSrcset(site.images.community);
const heroImageSizes = imageSizesFor("hero");
const heroPreload = {
  href: site.images.hero,
  srcset: heroImageSrcset,
  sizes: heroImageSizes,
  type: "image/webp",
};
---

<BaseLayout image={site.images.hero} imageAlt={site.home.hero.imageAlt} extraSchemas={homeSchemas} preloadImages={[heroPreload]}>
  <section class="hero" aria-labelledby="hero-title">
    <img class="hero__image" src={withBase(site.images.hero)} srcset={heroImageSrcset} sizes={heroImageSizes} alt={site.home.hero.imageAlt} width={heroImageSize?.width} height={heroImageSize?.height} loading="eager" decoding="async" fetchpriority="high" />
    <div class="hero__shade" aria-hidden="true"></div>
    <div class="shell hero__content">
      <p class="eyebrow">{site.home.hero.eyebrow}</p>
      <h1 id="hero-title">{site.home.hero.headline}</h1>
      <p class="hero__subheadline">{site.home.hero.subheadline}</p>
      <p>{site.home.hero.body}</p>
      <div class="hero__actions">
        <ButtonLink href={site.home.hero.primaryCta.href}>{site.home.hero.primaryCta.label}</ButtonLink>
        <ButtonLink href={site.home.hero.secondaryCta.href} variant="secondary">{site.home.hero.secondaryCta.label}</ButtonLink>
      </div>
    </div>
  </section>

  <section class="service-strip" aria-label="Sunday service information">
    <div class="shell service-strip__grid">
      <div>
        <p class="eyebrow">This Sunday</p>
        <h2>{site.service.primary.label}</h2>
      </div>
      <p><strong>{site.service.primary.day} at {site.service.primary.time}</strong><br />{site.service.primary.summary}</p>
      <p><strong>{site.service.coffee.label}: {site.service.coffee.time}</strong><br />{site.service.coffee.summary}</p>
      <div class="service-strip__actions">
        <ButtonLink href="/sunday-worship/" variant="secondary">Sunday Details</ButtonLink>
        <ButtonLink href="/plan-a-visit/" variant="text">Plan a Visit</ButtonLink>
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell split">
      <div>
        <SectionIntro eyebrow={site.localSeo.eyebrow} title={site.localSeo.homeTitle}>
          <p>{site.localSeo.homeBody}</p>
        </SectionIntro>
        <div class="button-row">
          <ButtonLink href="/church-in-charlton-ma/">Church in Charlton</ButtonLink>
          <ButtonLink href="/plan-a-visit/" variant="secondary">Plan a Visit</ButtonLink>
        </div>
      </div>

      <div class="quiet-box">
        <h2>Wayside Church</h2>
        <ChurchContactBlock showPhone={false} note={site.localSeo.localAreas} />
      </div>
    </div>
  </section>

  <section class="section visitor-section" aria-labelledby="visitor-title">
    <div class="shell visitor-grid">
      <div class="visitor-copy">
        <p class="eyebrow">{site.home.visit.eyebrow}</p>
        <h2 id="visitor-title">{site.home.visit.headline}</h2>
        <p>{site.home.visit.body}</p>
        <div class="button-row">
          <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
          <ButtonLink href="/start-here/" variant="secondary">Start Here</ButtonLink>
          <ButtonLink href="/new-to-church/" variant="secondary">New to Church</ButtonLink>
          <ButtonLink href={site.home.visit.familyCta.href} variant="secondary">{site.home.visit.familyCta.label}</ButtonLink>
        </div>
      </div>

      <div class="visitor-list">
        {site.home.visit.notes.map((note, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{note.title}</h3>
            <p>{note.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div>
        <SectionIntro eyebrow={site.home.mission.eyebrow} title={site.home.mission.headline}>
          <p>{site.home.mission.body}</p>
        </SectionIntro>
        <div class="mission-quote">
          <p>{site.church.mission}</p>
        </div>
      </div>
      <figure class="image-panel">
        <img src={withBase(site.images.community)} srcset={communityImageSrcset} sizes={imageSizesFor("panel")} alt="People sharing a meal at Wayside Church" width={communityImageSize?.width} height={communityImageSize?.height} loading="lazy" decoding="async" />
        <figcaption>Warm fellowship, practical care, and life together.</figcaption>
      </figure>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell">
      <SectionIntro eyebrow="Ministries" title="Gather with us and participate with Jesus">
        <p>Ministries at Wayside are simple on purpose: real people, shared Scripture, prayer, and room to grow.</p>
      </SectionIntro>
      <MinistryList limit={4} />
    </div>
  </section>

  <LatestTeaching latest={latestTeaching} />

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="Next steps" title="A few simple ways to begin">
        <p>Whether you are visiting for the first time or already part of Wayside, these are good places to start.</p>
      </SectionIntro>
      <div class="next-steps">
        {site.home.nextSteps.map((step) => (
          <a class="next-step" href={withBase(step.href)}>
            <span>{step.label}</span>
            <p>{step.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="scripture-band" aria-label={site.home.scripture.reference}>
    <div class="shell">
      <p>{site.home.scripture.reference}</p>
      <blockquote>{site.home.scripture.text}</blockquote>
    </div>
  </section>
</BaseLayout>
