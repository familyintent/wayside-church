---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import CalendarActions from "../components/CalendarActions.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SundayDate from "../components/SundayDate.astro";
import { site } from "../lib/content";
import { imageSize, imageSizesFor, imageSrcset } from "../lib/images";
import { withBase } from "../lib/paths";
import { getFaqPageSchema, getSundayWorshipEventSchema } from "../lib/schema";

const sunday = site.sundayPage;
const communityImageSize = imageSize(site.images.community);
const communityImageSrcset = imageSrcset(site.images.community);
const sundaySchemas = [getSundayWorshipEventSchema("/sunday-worship/"), getFaqPageSchema(sunday.faq)];
---

<BaseLayout title={sunday.metaTitle} description={sunday.metaDescription} image={site.images.community} imageAlt="Wayside Church family sharing a meal together in Charlton, Massachusetts" extraSchemas={sundaySchemas}>
  <section class="page-hero sunday-hero">
    <div class="shell page-hero__inner">
      <p class="eyebrow">{sunday.eyebrow}</p>
      <h1>{sunday.title}</h1>
      <p>{sunday.intro}</p>
      <div class="page-hero__actions">
        <ButtonLink href={sunday.primaryCta.href}>{sunday.primaryCta.label}</ButtonLink>
        <ButtonLink href={sunday.secondaryCta.href} variant="secondary">{sunday.secondaryCta.label}</ButtonLink>
      </div>
    </div>
  </section>

  <section class="service-strip" aria-label="Sunday worship information">
    <div class="shell service-strip__grid">
      <div>
        <p class="eyebrow">This Sunday, <SundayDate weekday={false} /></p>
        <h2>{site.service.primary.label}</h2>
      </div>
      <p><strong>{site.service.primary.day} at {site.service.primary.time}</strong><br />{site.service.primary.summary}</p>
      <p><strong>{site.service.coffee.label}: {site.service.coffee.time}</strong><br />{site.service.coffee.summary}</p>
      <ButtonLink href={site.links.maps} variant="secondary">Get Directions</ButtonLink>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div>
        <SectionIntro eyebrow={sunday.rhythm.eyebrow} title={sunday.rhythm.title}>
          <p>{sunday.rhythm.body}</p>
        </SectionIntro>

        <div class="start-timeline">
          {sunday.rhythm.items.map((item) => (
            <article>
              <span>{item.time}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>

      <figure class="image-panel">
        <img src={withBase(site.images.community)} srcset={communityImageSrcset} sizes={imageSizesFor("panel")} alt="Wayside Church family sharing a meal together" width={communityImageSize?.width} height={communityImageSize?.height} loading="lazy" decoding="async" />
        <figcaption>{site.contact.addressLine1}, {site.contact.cityStateZip}</figcaption>
      </figure>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell plan-basics">
      <SectionIntro eyebrow={sunday.expect.eyebrow} title={sunday.expect.title}>
        <p>{sunday.expect.body}</p>
      </SectionIntro>

      <div class="plan-basics__list">
        {sunday.expect.items.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell start-questions__grid">
      <div>
        <p class="eyebrow">{sunday.guest.eyebrow}</p>
        <h2>{sunday.guest.title}</h2>
        <p>{sunday.guest.body}</p>
        <div class="button-row">
          <ButtonLink href="/families/" variant="secondary">Families at Wayside</ButtonLink>
          <ButtonLink href="/start-here/" variant="secondary">Start Here</ButtonLink>
        </div>
      </div>

      <div class="belief-accordion">
        {sunday.faq.map((item, index) => (
          <details class="belief-item" open={index === 0}>
            <summary>
              <span>{item.question}</span>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--muted" id="sunday-calendar">
    <div class="shell">
      <CalendarActions id="sunday-calendar-actions" eyebrow="Save Sunday" title="Put Sunday Worship on your calendar." />
    </div>
  </section>

  <section class="visit-band">
    <div class="shell visit-band__inner">
      <div>
        <p class="eyebrow">Come worship with us</p>
        <h2>{site.service.primary.day}s at {site.service.primary.time}</h2>
        <p>{site.contact.addressLine1}, {site.contact.cityStateZip}</p>
      </div>
      <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
    </div>
  </section>
</BaseLayout>
