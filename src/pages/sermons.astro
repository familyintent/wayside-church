---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TeachingDate from "../components/TeachingDate.astro";
import { site } from "../lib/content";
import { getFaqPageSchema, getTeachingVideoSchemas } from "../lib/schema";
import { getTeachingPagePath } from "../lib/teaching-routes";
import { getRecentTeachings, getYouTubeThumbnailSize } from "../lib/youtube";

const sermons = site.sermonsPage;
const teachings = await getRecentTeachings(site.youtube, 6);
const latest = teachings[0];
const recent = teachings.slice(1);
const latestThumbnailSize = latest ? getYouTubeThumbnailSize(latest.thumbnail) : { width: 480, height: 360 };
const recentWithThumbnailSizes = recent.map((video) => ({
  video,
  thumbnailSize: getYouTubeThumbnailSize(video.thumbnail),
}));
const sermonSchemas = [...getTeachingVideoSchemas(teachings, "/sermons/"), getFaqPageSchema(sermons.faq)];
const pageDateModified = teachings.map((video) => video.published).filter(Boolean).sort().at(-1);
---

<BaseLayout title={sermons.metaTitle} description={sermons.metaDescription} dateModified={pageDateModified} extraSchemas={sermonSchemas}>
  <section class="page-hero page-hero--center">
    <div class="shell page-hero__inner">
      <p class="eyebrow">{sermons.eyebrow}</p>
      <h1>{sermons.title}</h1>
      <p>{sermons.intro}</p>
      <div class="page-hero__actions">
        <ButtonLink href={site.links.youtube}>YouTube Channel</ButtonLink>
        <ButtonLink href="/sunday-worship/" variant="secondary">Sunday Worship</ButtonLink>
      </div>
    </div>
  </section>

  {
    latest ? (
      <section class="section section--ink">
        <div class="shell">
          <SectionIntro eyebrow="Latest sermon" title={sermons.latestTitle}>
            <p>{sermons.latestIntro}</p>
          </SectionIntro>

          <article class="teaching-card teaching-card--feature">
            <a class="teaching-card__image" href={getTeachingPagePath(latest)} aria-label={`Watch ${latest.title}`}>
              <img src={latest.thumbnail} alt={`Thumbnail for ${latest.title}`} width={latestThumbnailSize.width} height={latestThumbnailSize.height} loading="eager" decoding="async" />
            </a>
            <div class="teaching-card__body">
              <p class="eyebrow">{latest.source === "featured" ? "Featured sermon" : "Newest upload"}</p>
              <h2>{latest.title}</h2>
              <p class="teaching-card__date"><TeachingDate video={latest} fallbackLabel="Wayside sermon" /></p>
              <div class="button-row">
                <ButtonLink href={getTeachingPagePath(latest)}>Watch Sermon</ButtonLink>
                <ButtonLink href={latest.url} variant="secondary">YouTube</ButtonLink>
                <ButtonLink href="/sunday-worship/" variant="secondary">Visit Sunday</ButtonLink>
              </div>
            </div>
          </article>
        </div>
      </section>
    ) : (
      <section class="section section--ink">
        <div class="shell teaching-fallback">
          <h2>{site.youtube.fallbackTitle}</h2>
          <p>{site.youtube.fallbackMessage}</p>
          <ButtonLink href={site.links.youtube}>Visit YouTube Channel</ButtonLink>
        </div>
      </section>
    )
  }

  {
    recent.length > 0 && (
      <section class="section">
        <div class="shell">
          <SectionIntro eyebrow="Recent messages" title={sermons.recentTitle}>
            <p>{sermons.recentIntro}</p>
          </SectionIntro>

          <div class="teaching-grid">
            {recentWithThumbnailSizes.map(({ video, thumbnailSize }) => (
              <article class="teaching-tile">
                <a class="teaching-tile__image" href={getTeachingPagePath(video)} aria-label={`Watch ${video.title}`}>
                  <img src={video.thumbnail} alt={`Thumbnail for ${video.title}`} width={thumbnailSize.width} height={thumbnailSize.height} loading="lazy" decoding="async" />
                </a>
                <div class="teaching-tile__body">
                  <p><TeachingDate video={video} fallbackLabel="Wayside sermon" /></p>
                  <h2>{video.title}</h2>
                  <a href={getTeachingPagePath(video)}>Watch Sermon</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="section section--muted">
    <div class="shell start-questions__grid">
      <div>
        <p class="eyebrow">Sermon FAQ</p>
        <h2>Before you listen or visit</h2>
        <p>These answers help guests understand how teaching fits into the life of Wayside Church.</p>
      </div>

      <div class="belief-accordion">
        {sermons.faq.map((item, index) => (
          <details class="belief-item" open={index === 0}>
            <summary>
              <span>{item.question}</span>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="visit-band">
    <div class="shell visit-band__inner">
      <div>
        <p class="eyebrow">Come hear Scripture with us</p>
        <h2>{sermons.visitTitle}</h2>
        <p>{site.service.primary.day} at {site.service.primary.time} at {site.contact.addressLine1}, {site.contact.cityStateZip}</p>
      </div>
      <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
    </div>
  </section>
</BaseLayout>
