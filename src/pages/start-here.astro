---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import CalendarActions from "../components/CalendarActions.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/content";

const start = site.startHere;
---

<BaseLayout title="Start Here" description="A gentle first step for seekers, first-time guests, and people new to faith at Wayside Church in Charlton, MA.">
  <section class="page-hero start-hero">
    <div class="shell page-hero__inner">
      <p class="eyebrow">{start.eyebrow}</p>
      <h1>{start.title}</h1>
      <p>{start.intro}</p>
      <div class="page-hero__actions">
        <ButtonLink href={start.primaryCta.href}>{start.primaryCta.label}</ButtonLink>
        <ButtonLink href={start.secondaryCta.href} variant="secondary">{start.secondaryCta.label}</ButtonLink>
      </div>
    </div>
  </section>

  <section class="section start-pathway">
    <div class="shell">
      <SectionIntro eyebrow={start.pathway.eyebrow} title={start.pathway.title}>
        <p>{start.pathway.body}</p>
      </SectionIntro>

      <div class="pathway-grid">
        {start.pathway.steps.map((step, index) => (
          <article class="pathway-card">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h2>{step.title}</h2>
            <p>{step.body}</p>
            <ButtonLink href={step.href} variant={index === 0 ? "primary" : "secondary"}>{step.cta}</ButtonLink>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--muted start-sunday">
    <div class="shell start-sunday__grid">
      <div>
        <p class="eyebrow">{start.sunday.eyebrow}</p>
        <h2>{start.sunday.title}</h2>
        <p>{start.sunday.body}</p>
      </div>

      <div class="start-timeline">
        {start.sunday.rhythm.map((item) => (
          <article>
            <span>{item.time}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <CalendarActions eyebrow="Make it easier" title="Save Sunday before the week gets busy." />
    </div>
  </section>

  <section class="section start-questions">
    <div class="shell start-questions__grid">
      <div>
        <p class="eyebrow">{start.questions.eyebrow}</p>
        <h2>{start.questions.title}</h2>
        <p>{start.questions.intro}</p>
      </div>

      <div class="belief-accordion">
        {start.questions.items.map((item, index) => (
          <details class="belief-item" open={index === 0}>
            <summary>
              <span>{item.question}</span>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="visit-band">
    <div class="shell visit-band__inner">
      <div>
        <p class="eyebrow">Ready for a next step?</p>
        <h2>Come Sunday, or watch a teaching first.</h2>
      </div>
      <div class="button-row">
        <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
        <ButtonLink href="/#latest-teaching" variant="secondary">Watch Teaching</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
