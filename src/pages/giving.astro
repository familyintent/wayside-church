---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { site } from "../lib/content";
---

<BaseLayout title="Give to Wayside Church" description="Give securely to Wayside Church and support worship, care, and local ministry in Charlton, MA.">
  <section class="page-hero page-hero--center">
    <div class="shell page-hero__inner">
      <p class="eyebrow">Giving</p>
      <h1>{site.givingPage.title}</h1>
      <p>{site.givingPage.intro}</p>
      <div class="page-hero__actions">
        <ButtonLink href={site.links.giving}>Give Online</ButtonLink>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell narrow">
      <p class="lead">{site.givingPage.body}</p>
      <div class="quiet-box">
        <h2>A secure way to give</h2>
        <p>The Give Online button opens GivingTools so you can complete your gift securely.</p>
      </div>
    </div>
  </section>
</BaseLayout>
