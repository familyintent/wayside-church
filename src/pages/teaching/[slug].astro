---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/ButtonLink.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import { site } from "../../lib/content";
import { getTeachingVideoSchema } from "../../lib/schema";
import { getTeachingEmbedUrl, getTeachingPagePath, getTeachingSlug } from "../../lib/teaching-routes";
import { formatPublishedDate, getRecentTeachings, getYouTubeThumbnailSize } from "../../lib/youtube";
import type { LatestTeaching } from "../../lib/youtube";

export async function getStaticPaths() {
  const teachings = await getRecentTeachings(site.youtube, 6);

  return teachings.map((video) => ({
    params: { slug: getTeachingSlug(video) },
    props: {
      video,
      relatedTeachings: teachings.filter((teaching) => teaching.videoId !== video.videoId).slice(0, 3),
    },
  }));
}

type Props = {
  video: LatestTeaching;
  relatedTeachings: LatestTeaching[];
};

const { video, relatedTeachings } = Astro.props;
const publishedDate = video.published ? formatPublishedDate(video.published) : video.publishedLabel;
const pagePath = Astro.url.pathname;
const cleanTitle = video.title.replace(/\s+/g, " ").trim();
const shortTitle = cleanTitle.length > 30 ? `${cleanTitle.slice(0, 27).trimEnd()}...` : cleanTitle;
const descriptionTitle = cleanTitle.length > 68 ? `${cleanTitle.slice(0, 65).trimEnd()}...` : cleanTitle;
const pageTitle = `Teaching: ${shortTitle} | ${site.church.name}`;
const description = `Watch ${descriptionTitle}, a recent Bible teaching from Wayside Church in Charlton, MA, and find a simple next step for Sunday.`;
const videoSchema = getTeachingVideoSchema(video, pagePath);
const thumbnailSize = getYouTubeThumbnailSize(video.thumbnail);
const thumbnailAlt = `Thumbnail for ${video.title}, a Wayside Church teaching video`;
const watchPage = site.teachingPage.watchPage;
const dateLabel = (teaching: LatestTeaching) => (teaching?.published ? formatPublishedDate(teaching.published) : teaching?.publishedLabel || "Wayside teaching");
const relatedWithThumbnailSizes = relatedTeachings.map((teaching) => ({
  teaching,
  thumbnailSize: getYouTubeThumbnailSize(teaching.thumbnail),
}));
---

<BaseLayout title={pageTitle} description={description} image={video.thumbnail} imageAlt={thumbnailAlt} imageWidth={thumbnailSize.width} imageHeight={thumbnailSize.height} breadcrumbLabel={video.title} extraSchemas={[videoSchema]}>
  <section class="video-watch">
    <div class="shell video-watch__grid">
      <div class="video-watch__copy">
        <p class="eyebrow">Wayside teaching</p>
        <h1>{video.title}</h1>
        {publishedDate && <p class="video-watch__date">{publishedDate}</p>}
        <p>{description}</p>
        <div class="button-row">
          <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
          <ButtonLink href={video.url} variant="secondary">Open on YouTube</ButtonLink>
        </div>
      </div>

      <div class="video-watch__frame" aria-label={`Video player for ${video.title}`}>
        <iframe
          src={getTeachingEmbedUrl(video)}
          title={`Watch ${video.title}`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell split">
      <SectionIntro eyebrow={watchPage.contextEyebrow} title={watchPage.contextTitle}>
        <p>{watchPage.contextBody}</p>
      </SectionIntro>

      <div class="quiet-box">
        <h2>Sunday at Wayside</h2>
        <p><strong>{site.service.primary.label}: {site.service.primary.time}</strong></p>
        <p>{site.service.coffee.label} begins at {site.service.coffee.time}. Wayside gathers at {site.contact.addressLine1}, {site.contact.cityStateZip}.</p>
        <div class="button-row">
          <ButtonLink href="/teaching/" variant="secondary">More Teaching</ButtonLink>
          <ButtonLink href="/sunday-worship/" variant="secondary">Sunday Details</ButtonLink>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell plan-basics">
      <SectionIntro eyebrow={watchPage.nextEyebrow} title={watchPage.nextTitle}>
        <p>{watchPage.nextBody}</p>
      </SectionIntro>

      <div class="plan-basics__list">
        {watchPage.steps.map((step, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h2>{step.title}</h2>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {
    relatedWithThumbnailSizes.length > 0 && (
      <section class="section section--muted">
        <div class="shell">
          <SectionIntro eyebrow={watchPage.relatedEyebrow} title={watchPage.relatedTitle}>
            <p>{watchPage.relatedBody}</p>
          </SectionIntro>

          <div class="teaching-grid">
            {relatedWithThumbnailSizes.map(({ teaching, thumbnailSize }) => (
              <article class="teaching-tile">
                <a class="teaching-tile__image" href={getTeachingPagePath(teaching)} aria-label={`Watch ${teaching.title}`}>
                  <img src={teaching.thumbnail} alt={`Thumbnail for ${teaching.title}`} width={thumbnailSize.width} height={thumbnailSize.height} loading="lazy" decoding="async" />
                </a>
                <div class="teaching-tile__body">
                  <p>{dateLabel(teaching)}</p>
                  <h2>{teaching.title}</h2>
                  <a href={getTeachingPagePath(teaching)}>Watch Teaching</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
