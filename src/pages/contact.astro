---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import CalendarActions from "../components/CalendarActions.astro";
import ChurchContactBlock from "../components/ChurchContactBlock.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/content";
import { imageSize, imageSizesFor, imageSrcset } from "../lib/images";
import { withBase } from "../lib/paths";
import { getFaqPageSchema } from "../lib/schema";

const charltonImageSize = imageSize(site.images.charlton);
const charltonImageSrcset = imageSrcset(site.images.charlton);
---

<BaseLayout title="Contact Wayside Church in Charlton, MA" description="Plan a visit to Wayside Church in Charlton, MA, find Sunday worship details, contact information, directions, and guest FAQs." image={site.images.charlton} imageAlt="Map of Charlton, Massachusetts near Wayside Church" extraSchemas={[getFaqPageSchema(site.contactPage.faq)]}>
  <section class="page-hero">
    <div class="shell page-hero__inner">
      <p class="eyebrow">Contact</p>
      <h1>{site.contactPage.title}</h1>
      <p>{site.contactPage.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="shell contact-grid">
      <div>
        <SectionIntro eyebrow="Come visit us" title={`${site.church.city}, ${site.church.state}`}>
          <p>{site.contactPage.visitCopy}</p>
        </SectionIntro>
        <ChurchContactBlock pluralDay />
        <div class="button-row">
          <ButtonLink href={site.links.maps}>Open in Maps</ButtonLink>
          <ButtonLink href="/directions/" variant="secondary">Directions</ButtonLink>
          <ButtonLink href="/wayside-church.vcf" variant="secondary">Save Contact</ButtonLink>
          <ButtonLink href={site.contact.phoneHref} variant="secondary">Call the Church</ButtonLink>
        </div>
      </div>

      <figure class="image-panel image-panel--map">
        <img src={withBase(site.images.charlton)} srcset={charltonImageSrcset} sizes={imageSizesFor("panel")} alt="Map of Charlton, Massachusetts" width={charltonImageSize?.width} height={charltonImageSize?.height} loading="lazy" decoding="async" />
        <figcaption>{site.contact.addressLine1}, {site.contact.cityStateZip}</figcaption>
      </figure>
    </div>

    <div class="shell section-action-wide">
      <CalendarActions id="contact-calendar" eyebrow="Visiting soon?" title="Save the Sunday gathering." />
    </div>
  </section>

  <section class="section section--muted" id="faq">
    <div class="shell">
      <SectionIntro eyebrow="FAQ" title="Frequently asked questions">
        <p>Helpful answers for guests and families planning a visit.</p>
      </SectionIntro>
      <div class="faq-list">
        {site.contactPage.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
