---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/content";
---

<BaseLayout title="Contact">
  <section class="page-hero">
    <div class="shell page-hero__inner">
      <p class="eyebrow">Contact</p>
      <h1>{site.contactPage.title}</h1>
      <p>{site.contactPage.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="shell contact-grid">
      <div>
        <SectionIntro eyebrow="Come visit us" title={`${site.church.city}, ${site.church.state}`}>
          <p>{site.contactPage.visitCopy}</p>
        </SectionIntro>
        <div class="contact-list">
          <p><strong>{site.service.primary.day}s at {site.service.primary.time}</strong></p>
          <p>{site.contact.addressLine1}<br />{site.contact.cityStateZip}</p>
          <p><a href={site.contact.phoneHref}>{site.contact.phone}</a></p>
        </div>
        <div class="button-row">
          <ButtonLink href={site.links.maps}>Open in Maps</ButtonLink>
          <ButtonLink href={site.contact.phoneHref} variant="secondary">Call the Church</ButtonLink>
        </div>
      </div>

      <figure class="image-panel image-panel--map">
        <img src={site.images.charlton} alt="Map of Charlton, Massachusetts" loading="lazy" />
        <figcaption>{site.contact.addressLine1}, {site.contact.cityStateZip}</figcaption>
      </figure>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell">
      <SectionIntro eyebrow="FAQ" title="Frequently asked questions">
        <p>Helpful answers for guests and families planning a visit.</p>
      </SectionIntro>
      <div class="faq-list">
        {site.contactPage.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
