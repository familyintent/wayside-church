---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/content";
import { imageSize, imageSizesFor, imageSrcset } from "../lib/images";
import { withBase } from "../lib/paths";
import { getLeaderId, getLeaderPersonSchemas } from "../lib/schema";

const aboutHero = site.about.hero;
const aboutSchemas = getLeaderPersonSchemas(site.about.leaders);
const aboutHeroImageSize = imageSize(aboutHero.image);
const aboutHeroImageSrcset = imageSrcset(aboutHero.image);
const leaders = site.about.leaders.map((leader) => ({
  ...leader,
  id: getLeaderId(leader),
  imageSize: imageSize(leader.image),
  imageSrcset: imageSrcset(leader.image),
}));
---

<BaseLayout title="About Wayside Church in Charlton, MA" description="Learn what Wayside Church believes, meet the leaders, and discover the Gospel-centered mission shaping this local church in Charlton, MA." image={aboutHero.image} imageAlt={aboutHero.imageAlt} extraSchemas={aboutSchemas}>
  <section class="about-hero" aria-labelledby="about-title">
    <div class="shell about-hero__grid">
      <div class="about-hero__copy">
        <p class="eyebrow">{aboutHero.eyebrow}</p>
        <h1 id="about-title">{site.about.title}</h1>
        <p>{site.about.intro}</p>
        <div class="button-row">
          <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
          <ButtonLink href="/ministries/" variant="secondary">Explore Ministries</ButtonLink>
        </div>
      </div>

      <div class="about-hero__media">
        <figure class="about-hero__image-frame">
          <img src={withBase(aboutHero.image)} srcset={aboutHeroImageSrcset} sizes={imageSizesFor("panel")} alt={aboutHero.imageAlt} width={aboutHeroImageSize?.width} height={aboutHeroImageSize?.height} loading="eager" decoding="async" />
          <figcaption>{aboutHero.caption}</figcaption>
        </figure>
        <div class="about-hero__cards" aria-label="Sunday gathering times">
          {aboutHero.cards.map((card) => (
            <div>
              <span>{card.label}</span>
              <strong>{card.value}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section about-story">
    <div class="shell about-story__grid">
      <div>
        <SectionIntro eyebrow="Our center" title={site.about.gospel.title}>
          <p>{site.about.gospel.body}</p>
        </SectionIntro>
        <div class="mission-quote">
          <p>{site.church.mission}</p>
        </div>
      </div>

      <div class="about-markers" aria-label="What shapes Wayside Church">
        {site.about.markers.map((marker, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h2>{marker.title}</h2>
            <p>{marker.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section about-fivefold">
    <div class="shell">
      <SectionIntro eyebrow="The ministry of Jesus" title={site.about.fiveFold.title}>
        <p>{site.about.fiveFold.body}</p>
      </SectionIntro>

      <div class="fivefold-list">
        {site.about.fiveFold.items.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="shell">
      <SectionIntro eyebrow="Our leaders" title="Meet Chase and Owen">
        <p>{site.about.leadersIntro}</p>
      </SectionIntro>
      <div class="leader-grid leader-grid--feature">
        {leaders.map((leader) => (
          <article class="leader-card leader-card--feature" id={leader.id}>
            <img src={withBase(leader.image)} srcset={leader.imageSrcset} sizes={imageSizesFor("leader")} alt={leader.name} width={leader.imageSize?.width} height={leader.imageSize?.height} loading="lazy" decoding="async" />
            <div class="leader-card__body">
              <p class="eyebrow">{leader.role}</p>
              <h3>{leader.name}</h3>
              <p>{leader.bio}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="section-action">
        <ButtonLink href="/leadership/" variant="secondary">Leadership Page</ButtonLink>
      </div>
    </div>
  </section>

  <section class="section about-faith">
    <div class="shell about-faith__grid">
      <div>
        <p class="eyebrow">Statement of faith</p>
        <h2>Our statement of faith</h2>
        <p>{site.about.faithIntro}</p>
        <p>{site.about.gatheringNote}</p>
        <ButtonLink href="/beliefs/" variant="text">Read More About Our Beliefs</ButtonLink>
      </div>

      <div class="belief-accordion">
        {site.about.beliefs.map((belief, index) => (
          <details class="belief-item" open={index === 0}>
            <summary>
              <span>{belief.title}</span>
            </summary>
            <p>{belief.body}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="visit-band">
    <div class="shell visit-band__inner">
      <div>
        <p class="eyebrow">Come visit us</p>
        <h2>{site.service.primary.day}s at {site.service.primary.time}</h2>
        <p>{site.contact.addressLine1}, {site.contact.cityStateZip}</p>
      </div>
      <ButtonLink href="/plan-a-visit/">Plan a Visit</ButtonLink>
    </div>
  </section>
</BaseLayout>
