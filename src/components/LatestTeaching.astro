---
import ButtonLink from "./ButtonLink.astro";
import SectionIntro from "./SectionIntro.astro";
import { site } from "../lib/content";
import { getTeachingPagePath } from "../lib/teaching-routes";
import { formatPublishedDate, getLatestTeaching, getYouTubeThumbnailSize } from "../lib/youtube";
import type { LatestTeaching } from "../lib/youtube";

type Props = {
  latest?: LatestTeaching | null;
};

const { latest: providedLatest } = Astro.props;
const latest = providedLatest === undefined ? await getLatestTeaching(site.youtube) : providedLatest;
const latestLabel = latest?.source === "featured" ? "Featured teaching" : "Newest upload";
const latestDate = latest?.published ? formatPublishedDate(latest.published) : latest?.publishedLabel;
const latestPath = latest ? getTeachingPagePath(latest) : "";
const latestThumbnailSize = latest ? getYouTubeThumbnailSize(latest.thumbnail) : { width: 480, height: 360 };
---

<section class="section section--ink" id="latest-teaching" aria-labelledby="latest-teaching-title">
  <div class="shell">
    <SectionIntro eyebrow="Latest teaching" title="Watch and experience our latest teaching" align="center">
      <p>Catch up on the latest message from Wayside Church.</p>
    </SectionIntro>

    {
      latest ? (
        <article class="teaching-card" aria-labelledby="latest-teaching-title">
          <a class="teaching-card__image" href={latestPath} aria-label={`Watch ${latest.title}`}>
            <img src={latest.thumbnail} alt={`Thumbnail for ${latest.title}`} width={latestThumbnailSize.width} height={latestThumbnailSize.height} loading="lazy" decoding="async" />
          </a>
          <div class="teaching-card__body">
            <p class="eyebrow">{latestLabel}</p>
            <h3 id="latest-teaching-title">{latest.title}</h3>
            {latestDate && <p class="teaching-card__date">{latestDate}</p>}
            <div class="button-row">
              <ButtonLink href={latestPath}>Watch Teaching</ButtonLink>
              <ButtonLink href="/teaching/" variant="secondary">More Teaching</ButtonLink>
            </div>
          </div>
        </article>
      ) : (
        <div class="teaching-fallback">
          <h3 id="latest-teaching-title">{site.youtube.fallbackTitle}</h3>
          <p>{site.youtube.fallbackMessage}</p>
          <div class="button-row">
            <ButtonLink href={site.links.youtube}>Visit YouTube Channel</ButtonLink>
            <ButtonLink href="/teaching/" variant="secondary">Teaching Page</ButtonLink>
          </div>
        </div>
      )
    }
  </div>
</section>
