---
import Logo from "./Logo.astro";
import { site } from "../lib/content";
import { withBase } from "../lib/paths";

const year = new Date().getFullYear();
const socialLinks = [
  { label: "Facebook", href: site.links.facebook },
  { label: "Instagram", href: site.links.instagram },
  { label: "YouTube", href: site.links.youtube },
].filter((link) => link.href);
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-brand">
      <a href={withBase("/")} aria-label="Wayside Church home">
        <Logo compact tone="white" />
      </a>
      <p>{site.church.mission}</p>
      {
        socialLinks.length > 0 && (
          <div class="social-links" aria-label="Social links">
            {socialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div class="footer-contact">
      <h2>Gather With Us</h2>
      <p><strong>{site.service.primary.day}s at {site.service.primary.time}</strong></p>
      <p>{site.contact.addressLine1}<br />{site.contact.cityStateZip}</p>
      <p><a href={site.contact.phoneHref}>{site.contact.phone}</a></p>
    </div>

    <div class="footer-links">
      <h2>Pages</h2>
      <a href={withBase("/about/")}>About</a>
      <a href={withBase("/ministries/")}>Ministries</a>
      <a href={withBase("/contact/")}>Contact</a>
      <a href={withBase("/newsletter/")}>Newsletter</a>
      <a href={withBase("/giving/")}>Giving</a>
    </div>
  </div>

  <div class="shell footer-bottom">
    <p>Copyright {year} Wayside Church</p>
  </div>
</footer>
