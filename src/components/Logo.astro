---
type Props = {
  compact?: boolean;
  tone?: "auto" | "navy" | "white";
};

import { withBase } from "../lib/paths";

const { compact = false, tone = "auto" } = Astro.props;
---

<span class:list={["logo", `logo--${tone}`, { "logo--compact": compact }]} aria-label="Wayside Church">
  <span class="logo__mark" aria-hidden="true">
    <img class="logo__image logo__image--navy" src={withBase("/images/wayside-logo-mark-navy.png")} alt="" width="361" height="546" loading="eager" decoding="async" />
    <img class="logo__image logo__image--white" src={withBase("/images/wayside-logo-mark-white.png")} alt="" width="361" height="546" loading="eager" decoding="async" />
  </span>
  <span class="logo__text">
    <span>Wayside</span>
    <span>Church</span>
  </span>
</span>
