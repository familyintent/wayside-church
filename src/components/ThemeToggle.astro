<button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle dark mode">
  <svg class="theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
  </svg>
  <svg class="theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M20 14.7A8 8 0 0 1 9.3 4a7 7 0 1 0 10.7 10.7Z"></path>
  </svg>
</button>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

  for (const button of buttons) {
    button.addEventListener("click", () => {
      const current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("wayside-theme", next);
    });
  }
</script>
